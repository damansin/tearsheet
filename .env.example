# Copy this file to `.env` (which is gitignored) and fill in your real keys.

# LLM provider for the agent.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Observability (LangSmith). TRACING is the master on/off switch; PROJECT
# groups runs under one name in the LangSmith UI.
LANGSMITH_API_KEY=lsv2-your-key-here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=tearsheet
